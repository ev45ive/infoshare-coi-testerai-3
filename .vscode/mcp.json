{
    "servers": {
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest"
            ]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": [
                "-y",
                "chrome-devtools-mcp@latest"
            ]
        },
        "dbhub": {
            "command": "npx",
            "args": [
                "@bytebase/dbhub@latest",
                "--transport",
                "stdio",
                "--host",
                "127.0.0.1",
                "--port",
                "8080",
                "--dsn",
                "sqlite://./shopeasy-demo/dev.db"
            ]
        },
    }
}